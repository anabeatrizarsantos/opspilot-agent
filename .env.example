# Copy this file to .env and replace the values below.
# This example is for Azure OpenAI; other LLM providers may require different variables (see docs or source).

AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-chat-completion-deployment-name
AZURE_OPENAI_API_VERSION=your-api-version
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=your-embeddings-deployment-name
